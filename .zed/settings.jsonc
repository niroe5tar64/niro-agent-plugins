{
  "format_on_save": "on",
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
  },
  "languages": {
    "JavaScript": {
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TypeScript": {
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "JSON": {
      "language_servers": ["biome", "!json-language-server"],
      "formatter": {
        "language_server": { "name": "biome" },
      },
    },
  },
}
